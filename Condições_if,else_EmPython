      "source": [
        "#Escreva um programa que faça o computador \"pensar\" em um numero inteiro de 0 e\n",
        "#5 e peça para o usuario tentar descobrir qual foi o numero escolhido pelo\n",
        "#comoutador. O programa devera escrever na tela se o usuario venceu ou perdeu.\n",
        "\n",
        "#SORTEIO\n",
        "\n",
        "import random\n",
        "\n",
        "sorteio = [0, 1, 2, 3, 4, 5]\n",
        "numero_sorteado = random.choice(sorteio)\n",
        "numero = int(input(\"Escolha um numero de 0 a 5: \"))\n",
        "\n",
        "if numero == numero_sorteado:\n",
        "    print(\"Você venceu!\")\n",
        "else:\n",
        "    print(\"O computador venceu!\")"
      ]
